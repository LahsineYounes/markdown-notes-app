# Android generated files
*.iml
.gradle
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties
*.jks
*.keystore

# Never commit these:
# local.properties  → contains SDK path (machine-specific)
# .idea/            → IDE settings (conflicts between team members)
# *.keystore        → signing keys (security risk!)
# /build/           → compiled output (auto-generated, wastes space)
